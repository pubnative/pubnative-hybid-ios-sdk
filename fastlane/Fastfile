# fastlane/Fastfile
opt_out_usage

require 'base64'
require 'tempfile'
require 'fileutils'

def running_on_ci?
  ENV['CIRCLECI'] == "true"
end

# Decode Apple API key stored in APP_STORE_CONNECT_PRIVATE_KEY_BASE64
def decode_api_key_from_env
  UI.message("🔐 Decoding Apple API Key...")

  key_base64 = ENV['APP_STORE_CONNECT_PRIVATE_KEY_BASE64']
  key_id     = ENV['APP_STORE_CONNECT_KEY_ID']
  issuer_id  = ENV['APP_STORE_CONNECT_ISSUER_ID']

  if key_base64.nil? || key_id.nil? || issuer_id.nil?
    UI.user_error!("Missing one of the required ENV vars: APP_STORE_CONNECT_PRIVATE_KEY_BASE64, APP_STORE_CONNECT_KEY_ID, APP_STORE_CONNECT_ISSUER_ID")
  end

  key_content = Base64.decode64(key_base64)
  file = Tempfile.new(['AuthKey', '.p8'])
  file.write(key_content)
  file.close

  { key_id: key_id, issuer_id: issuer_id, key_filepath: file.path }
end

before_all do
  if running_on_ci?
    UI.message("🔑 Running on CircleCI — using a temporary keychain.")
  end
end

platform :ios do

  desc "Fetch provisioning profiles & certs"
  lane :setup_signing do
    if running_on_ci?
      api_key_info = decode_api_key_from_env

      app_store_connect_api_key(
        key_id: api_key_info[:key_id],
        issuer_id: api_key_info[:issuer_id],
        key_filepath: api_key_info[:key_filepath],
        in_house: false
      )

      match(
        type: "adhoc",
        readonly: true,
        app_identifier: ["com.pubnative.HyBid.demo"],
        git_url: "https://github.com/vervegroup/iOSHyBidCertificates.git",
        keychain_name: "fastlane_tmp_keychain-db",
        keychain_password: "" # empty password for CI
      )

      sh "security set-key-partition-list -S apple-tool:,apple:,codesign: -s -k '' ~/Library/Keychains/fastlane_tmp_keychain-db"
    else
      match(
        type: "adhoc",
        readonly: true,
        keychain_name: "login.keychain-db"
      )
    end
  end

  desc "Build Ad-hoc IPA with version bump"
  lane :build do
    setup_signing

    base_folder = "/tmp/circleci-artifacts"
    archive_path = "#{base_folder}/archive.xcarchive"
    output_folder = "#{base_folder}/ipa"

    # Clean previous artifacts
    FileUtils.rm_rf(archive_path) if File.exist?(archive_path)
    FileUtils.rm_rf(output_folder) if Dir.exist?(output_folder)

    # Get repo root
    repo_root = File.expand_path(ENV['CIRCLE_WORKING_DIRECTORY'] || Dir.pwd)
    
    # Folder containing the .xcodeproj
    pubnative_folder = File.join(repo_root, "PubnativeLite")
    
    unless Dir.exist?(pubnative_folder)
        UI.user_error!("Directory '#{pubnative_folder}' does not exist! Check your path.")
    end
    
    Dir.chdir(pubnative_folder) do
    # Bump marketing version
    sh "agvtool -noscm new-marketing-version \"$(agvtool what-marketing-version -terse1)-#{ENV['CIRCLE_BRANCH']}.#{ENV['CIRCLE_BUILD_NUM']}\""
    
    # Bump build number
    build_num = ENV['CIRCLE_BUILD_NUM'] || '1'
    sh "agvtool new-version -all #{build_num}"
    end

    # Cleanup unnecessary files
    sh "find . -name '*.DS_Store' -type f -delete"
    sh "xattr -cr . || true"

    # After bumping versions in PubnativeLite
    Dir.chdir(repo_root) do
        # List workspace contents (optional)
        sh "xcodebuild -workspace HyBid.xcworkspace -list"
    end

    # Build IPA
    gym(
      workspace: File.join(repo_root, "HyBid.xcworkspace"),
      scheme: "HyBidDemo",
      configuration: "Release",
      clean: true,
      export_method: "ad-hoc",
      output_directory: "./build",
      output_name: "HyBidDemo.ipa",
      include_symbols: false,
      silent: false,
      verbose: true,
      export_options: {
        provisioningProfiles: {
          "com.pubnative.HyBid.demo" => "match AdHoc com.pubnative.HyBid.demo"
        }
      },
      xcargs: 'OTHER_CODE_SIGN_FLAGS="--keychain /Users/distiller/Library/Keychains/fastlane_tmp_keychain-db"'
    )
  end

  desc "Distribute IPA to Firebase"
  lane :distribute do
    build

    commit_hash   = ENV['CIRCLE_SHA1'].to_s[0..6]
    commit_author = ENV['CIRCLE_USERNAME'].to_s.strip

    # Avoid nulls by providing defaults
    commit_hash   = "unknown" if commit_hash.empty?
    commit_author = "unknown" if commit_author.empty?

    firebase_app_distribution(
      app: ENV['FIREBASE_APP_ID'],
      service_credentials_file: "firebase.json",
      ipa_path: "./build/HyBidDemo.ipa",
      release_notes: "🔧 Build: #{ENV['CIRCLE_BUILD_NUM']}\n🌿 Branch: #{ENV['CIRCLE_BRANCH']}\n#️⃣ Commit: #{commit_hash}\n✍️ Author: #{commit_author}"
    )
  end
end
