# fastlane/Fastfile

opt_out_usage
default_platform(:ios)

require 'base64'
require 'tempfile'

# 🔐 Decode Apple API key from ENV vars
def decode_api_key_from_env
  UI.message("🔐 Decoding Apple API Key...")

  key_base64 = ENV['APP_STORE_CONNECT_PRIVATE_KEY_BASE64']
  key_id     = ENV['APP_STORE_CONNECT_KEY_ID']
  issuer_id  = ENV['APP_STORE_CONNECT_ISSUER_ID']

  unless key_base64 && key_id && issuer_id
    UI.user_error!("❌ Missing required ENV vars: APP_STORE_CONNECT_PRIVATE_KEY_BASE64, APP_STORE_CONNECT_KEY_ID, APP_STORE_CONNECT_ISSUER_ID")
  end

  decoded_key = Base64.decode64(key_base64)

  result = nil
  Tempfile.new(["AuthKey_#{key_id}", ".p8"]) do |key_file|
    key_file.write(decoded_key)
    key_file.rewind
    UI.success("✅ API Key decoded successfully")
    result = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: key_file.path,
      in_house: false
    )
  end
  result  

rescue => e
  UI.user_error!("❌ Failed to decode API key: #{e.message}")
end

platform :ios do
  before_all do
    setup_circle_ci
  end

  desc "🚀 Ad-Hoc Build and Upload to Firebase"
  lane :distribute do |options|
    clear_derived_data

    update_code_signing_settings(use_automatic_signing: false)

    api_key = decode_api_key_from_env

    match(
      type: "development",
      api_key: api_key,
      git_url: "https://github.com/vervegroup/iOSHyBidCertificates.git",
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"]
    )

    cocoapods(
      repo_update: true,
      clean_install: true,
      podfile: "../Podfile",
      verbose: true
    )

  build_number = ENV["CIRCLE_BUILD_NUM"] || lane_context[:BUILD_NUMBER] || "N/A"
  branch = ENV["CIRCLE_BRANCH"] || `git rev-parse --abbrev-ref HEAD`.strip

  # 🔖 Generate Firebase release notes
  release_notes = <<~NOTES
    🛠 Build: #{build_number}
    🌿 Branch: #{branch}
  NOTES

    gym(
      include_bitcode: true,
      include_symbols: true,
      clean: true,
      configuration: "Debug",
      workspace: "../HyBid.xcworkspace",
      scheme: "HyBidDemo",
      archive_path: "/tmp/circleci-artifacts/archive.xcarchive",
      output_directory: "/tmp/circleci-artifacts/ipa",
      export_method: "development",
      export_options: "PubnativeLiteDemo/options.plist"
    )

    firebase_app_distribution(
      app: "1:786277539067:ios:8b6750af0afc3240ab245e",
      ipa_path: "/tmp/circleci-artifacts/ipa/HyBidDemo.ipa",
      release_notes: release_notes
    )

    UI.success("🎉 Firebase distribution complete!")
  end
end